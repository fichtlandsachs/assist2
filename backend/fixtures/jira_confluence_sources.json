      "embedding_policy": {"model": "ionos-embed", "batch_size": 32, "dimensions": 1024},
      "refresh_policy": {"schedule_cron": "0 4 * * 0", "use_etag": true, "use_last_modified": true, "force_reindex_on_hash_change": true},
      "metadata_defaults": {
        "vendor": "jira",
        "doc_category": "jira_software",
        "language": "en"
      }
    }
